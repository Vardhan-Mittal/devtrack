generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  cfHandle      String?   // Optional Codeforces handle
  lcUsername    String?   // Optional LeetCode username
  ccHandle      String?   // Optional CodeChef handle
  unstopProfile String?   // Optional Unstop profile URL
  githubUsername String?  // Optional GitHub username
  remindersOn   Boolean   @default(true)
  reminderMins  Int       @default(30) // Minutes before contest to remind

  accounts      Account[]
  sessions      Session[]
  contestStatus   UserContestStatus[]
  hackathonStatus UserHackathonStatus[]
  tasks           Task[]
  projects      Project[]
  reminderLogs  ReminderLog[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Contest {
  id          String    @id @default(uuid())
  externalId  String    @unique // e.g. "CF-1980" or "LC-biweekly-130"
  platform    String    // "CODEFORCES" or "LEETCODE"
  title       String
  startTime   DateTime
  durationSec Int
  url         String
  
  statuses    UserContestStatus[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum ContestIntent {
  REGISTERED
  INTERESTED
  NOT_REGISTERED
}

model UserContestStatus {
  id        String        @id @default(uuid())
  userId    String
  contestId String
  intent    ContestIntent @default(NOT_REGISTERED)

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId])
}

model UserHackathonStatus {
  id          String        @id @default(uuid())
  userId      String
  hackathonId String
  intent      ContestIntent @default(NOT_REGISTERED)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@unique([userId, hackathonId])
}

model Hackathon {
  id           String    @id @default(uuid())
  externalId   String    @unique
  platform     String    @default("UNSTOP")
  title        String
  organizer    String?
  deadline     DateTime
  startDate    DateTime?
  endDate      DateTime?
  url          String
  prizePool    String?
  teamSize     String?
  isOnline     Boolean   @default(true)
  
  statuses     UserHackathonStatus[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Task {
  id        String    @id @default(uuid())
  userId    String
  title     String
  completed Boolean   @default(false)
  priority  String    @default("MEDIUM") // "HIGH", "MEDIUM", "LOW"
  dueDate   DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum ProjectStatus {
  PLANNED
  ONGOING
  COMPLETED
}

model Project {
  id          String        @id @default(uuid())
  userId      String
  title       String
  description String?       @db.Text
  status      ProjectStatus @default(PLANNED)
  techStack   String[]      // e.g. ["Next.js", "Prisma", "Tailwind"]
  repoUrl     String?
  liveUrl     String?
  notes       String?       @db.Text
  roadmap     Json?         // AI generated folder structure & milestones
  deadline    DateTime?
  progress    Int           @default(0) // 0 to 100%

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ReminderLog {
  id        String   @id @default(uuid())
  userId    String
  contestId String
  sentAt    DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
